modules = ["nodejs-24", "php-8.2", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CommsCRM Frontend"

[[workflows.workflow]]
name = "CommsCRM Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/commscrm-temp/frontend && PORT=4000 node node_modules/.bin/vite --host 0.0.0.0 --port 4000 --strictPort"
waitForPort = 4000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "12c6dcaf1b28f34b4dd9c347547201f06b4a5f52f30e19662c957ed64792ed3568f822ba34c991daa24ae941876bca0e"
